Decouple the player from mcp_app.

The UI resolves the player via the vite alias (+ its own node_modules), never
via the `file:../player` npm dep — which only forced a frozen install to find a
player checkout. Drop the dep so the server builds standalone, and fix the alias
(upstream's `../../player/src` escapes the repo) to the ../player sibling the
build supplies withPlayer. Server-only just never supplies it.

--- a/package.json
+++ b/package.json
@@ -26,8 +26,7 @@
     "fflate": "^0.8.3",
     "fzstd": "^0.1.1",
     "zod": "^4.4.3",
-    "tsx": "^4.22.4",
-    "@openreplay/player": "file:../player"
+    "tsx": "^4.22.4"
   },
   "devDependencies": {
     "@types/node": "^25.2.3",
--- a/vite.config.ts
+++ b/vite.config.ts
@@ -7,7 +7,7 @@
   plugins: [react(), viteSingleFile()],
   resolve: {
     alias: {
-      '@openreplay/player': path.resolve(__dirname, '../../player/src'),
+      '@openreplay/player': path.resolve(__dirname, '../player/src'),
     },
   },
