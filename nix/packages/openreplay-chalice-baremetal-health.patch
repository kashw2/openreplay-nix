 def app_connection_string(name, port, path):
-    namespace = config("POD_NAMESPACE", default="app")
-    conn_string = config("CLUSTER_URL", default="svc.cluster.local")
-    return f"http://{name}.{namespace}.{conn_string}:{port}/{path}"
+    namespace = config("POD_NAMESPACE", default="")
+    if namespace:
+        # Kubernetes: resolve via the pod's service DNS, as upstream does.
+        conn_string = config("CLUSTER_URL", default="svc.cluster.local")
+        return f"http://{name}.{namespace}.{conn_string}:{port}/{path}"
+    # Bare-metal / single-host: no cluster DNS exists, so probe the service on
+    # loopback at its own /health port. HEALTH_HOST overrides the host (e.g. the
+    # deployment's listen address).
+    host = config("HEALTH_HOST", default="127.0.0.1")
+    port = LOOPBACK_HEALTH_PORTS.get(name, port)
+    return f"http://{host}:{port}/{path}"
 
 
