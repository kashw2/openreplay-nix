+# Opinionated /health ports per service for non-Kubernetes, single-host deploys,
+# matching the port each backend binds when POD_NAMESPACE is unset (the Go metrics
+# server's per-service default, and the assist / sourcemapreader / alerts services).
+# Keep in sync with the backend metrics server and the NixOS module's `metricsPort`
+# defaults. HEALTH_HOST overrides the host; HEALTH_ENDPOINT_<SERVICE> a whole URL.
+LOOPBACK_HEALTH_PORTS = {
+    "alerts-openreplay": 8113,
+    "assets-openreplay": 8125,
+    "assist-openreplay": 8108,
+    "db-openreplay": 8122,
+    "ender-openreplay": 8132,
+    "heuristics-openreplay": 8126,
+    "http-openreplay": 8120,
+    "integrations-openreplay": 8127,
+    "sink-openreplay": 8121,
+    "sourcemapreader-openreplay": 8112,
+    "storage-openreplay": 8124,
+}
+
